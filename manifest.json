{
  "manifest_version": 3,
  "name": "HRLens Auto Check-in",
  "version": "1.3.0",
  "description": "Automatically checks you in on HRLens when you open Chrome at the office.",
  "permissions": ["storage", "notifications", "geolocation", "alarms"],
  "host_permissions": [
    "https://hrlens.kredo.in/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HRLens Auto Check-in"
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://hrlens.kredo.in/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
